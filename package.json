  },
  "homepage": "https://github.com/mcdhrts/ioBroker.asuswrt#readme",
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
